# ============================================
# VMS Environment Variables — TEMPLATE
# ============================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# ============================================

# Django
DJANGO_SETTINGS_MODULE=vehicle_management.settings
DJANGO_SECRET_KEY=change-me-to-a-random-secret
DJANGO_DEBUG=True

# Database
DB_NAME=vms
DB_USER=admin
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# CORS
CORS_ALLOW_ALL=True

# API Keys
ZEPTO_API_KEY=
GOOGLE_MAPS_API_KEY=
